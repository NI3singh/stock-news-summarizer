# ---- Required API keys ----
# GEMINI: create at https://aistudio.google.com/apikey (must start with "AIza" and
#         have the Generative Language API enabled — a plain Firebase/GCP key 401s).
GEMINI_API_KEY=your_gemini_api_key_here
POLYGON_API_KEY=your_polygon_api_key_here

# ---- Operational (sensible defaults) ----
REFRESH_TIME=08:00
TIMEZONE=Asia/Kolkata
LOG_LEVEL=INFO
DB_PATH=./stockstalker.db
MAX_CONCURRENT_TICKERS=3

# ---- Deployment: Postgres / Supabase (optional) ----
# Leave UNSET for local dev (uses the SQLite DB_PATH above). Set it to deploy
# against Supabase Postgres. Use the Supabase "Connection string" (URI) for the
# Transaction or Session pooler — NOT the anon/service API keys:
#   Project Settings -> Database -> Connection string -> URI
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ---- StockStalker v2 LLM module (provider-agnostic factory) ----
LLM_PROVIDER=google
DEEP_THINK_LLM=gemini-2.5-flash
QUICK_THINK_LLM=gemini-2.5-flash-lite
# Optional tuning knobs (unset = provider default):
# TEMPERATURE=
# BACKEND_URL=                 # custom OpenAI-compatible endpoint
# GOOGLE_THINKING_LEVEL=       # Gemini ("high"/"low"/...)
# OPENAI_REASONING_EFFORT=     # OpenAI ("low"/"medium"/"high")
# ANTHROPIC_EFFORT=            # Anthropic extended thinking
# Optional provider keys (only if you switch LLM_PROVIDER; 'google' reuses GEMINI_API_KEY above):
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# GROQ_API_KEY=
# DEEPSEEK_API_KEY=
# XAI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ---- StockStalker Phase B: Telegram integration (optional) ----
# 1. Create a bot with @BotFather on Telegram -> copy the token.
# 2. Message your bot once, then open
#    https://api.telegram.org/bot<token>/getUpdates to find your numeric chat id.
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_personal_chat_id

# ---- StockStalker Phase C: MCP server (optional) ----
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=8765
